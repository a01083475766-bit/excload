# 데이터베이스 (기존과 동일)
# DATABASE_URL=
# DIRECT_URL=

# NextAuth
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=https://your-production-domain.com

# 토스페이먼츠 — 자동결제(빌링) 테스트 키는 개발자센터·문서에서 발급·확인
# 서버 전용 (절대 클라이언트 번들에 넣지 말 것)
TOSS_SECRET_KEY=test_sk_zXLkKEypNArWmo50nX3lmeaxYG5R

# 클라이언트 키는 브라우저에 노출되므로 NEXT_PUBLIC_ 접두사 필수 (Next.js App Router)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_D5GePWvyJnrK0W0k6q8gLzN97Eoq

# 배포 시 고정 도메인이 있으면 설정 (선택, 토스 리다이렉트는 클라이언트에서 origin 사용)
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# 체험(/trial) 한도 우회 (서버 전용)
# 브라우저 5회 카운트 무시 — 로컬 .env 에만 두는 것을 권장. 배포 서버에 넣으면 모든 방문자에게 적용됨.
# TRIAL_BYPASS_BROWSER_LIMIT=1
# IP 5회 카운트·차단 제외(쉼표 구분 공인 IP). 집/사무실 공인 IP만 넣을 것.
# TRIAL_BYPASS_IPS=203.0.113.10
