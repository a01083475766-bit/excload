# --- Prisma / PostgreSQL (필수) ---
# Supabase: Project Settings > Database
# - DATABASE_URL: Transaction pooler (예: 포트 6543, ?pgbouncer=true)
# - DIRECT_URL: Direct connection (예: 포트 5432) — migrate deploy 에 필요
# 풀러 없이 단일 접속만 쓰는 DB면 두 값에 동일한 URL 을 넣어도 됩니다.
DATABASE_URL=
DIRECT_URL=

# 사이트 기본 URL (이메일 인증 링크 등)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
