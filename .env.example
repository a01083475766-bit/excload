DATABASE_URL=
DIRECT_URL=
NEXTAUTH_SECRET=

# Password reset mail
RESEND_API_KEY=
EMAIL_FROM=noreply@excload.com
# Optional: if set, this value is preferred over EMAIL_FROM
PASSWORD_RESET_EMAIL_FROM=
# Optional: secret for hashing password reset code
PASSWORD_RESET_CODE_SECRET=
# 데이터베이스 (기존과 동일)
# DATABASE_URL=
# DIRECT_URL=

# NextAuth
# NEXTAUTH_SECRET=
# 운영 예: https://www.excload.com (끝 슬래시 없이, 실제 접속 도메인과 동일)
# NEXTAUTH_URL=https://your-production-domain.com
# OAuthCallback 디버깅 시에만 true → Vercel 로그 확인 후 삭제
# NEXTAUTH_DEBUG=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 토스페이먼츠 — 자동결제(빌링) 테스트 키는 개발자센터·문서에서 발급·확인
# 서버 전용 (절대 클라이언트 번들에 넣지 말 것)
TOSS_SECRET_KEY=test_sk_zXLkKEypNArWmo50nX3lmeaxYG5R

# 클라이언트 키는 브라우저에 노출되므로 NEXT_PUBLIC_ 접두사 필수 (Next.js App Router)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_D5GePWvyJnrK0W0k6q8gLzN97Eoq

# 배포 시 고정 도메인이 있으면 설정 (선택, 토스 리다이렉트는 클라이언트에서 origin 사용)
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# 체험 한도는 app/lib/trial-access.ts 의 TRIAL_ACCESS_LIMITS_ENABLED 로 켜고 끔.
# (예전) IP 화이트리스트만 쓸 때:
# TRIAL_BYPASS_IPS=203.0.113.10
